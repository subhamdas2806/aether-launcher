<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="GameShelf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GameShelf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Aether"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- The Frame hosts pages and extends edge-to-edge -->
        <Frame x:Name="RootFrame" />

        <!-- TitleBar is overlaid on top with transparent background for drag-handling -->
        <TitleBar x:Name="AppTitleBar" Title="" Background="Transparent" VerticalAlignment="Top" Height="48">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>
    </Grid>
</Window>
