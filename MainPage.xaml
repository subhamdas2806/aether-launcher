<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Aether.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aether"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="24,12,24,24" RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4">
                <TextBlock Text="AETHER" FontSize="28" FontWeight="Bold" Foreground="#A29BFE" />
                <TextBlock Text="Launch and track playtime of standalone and custom builds" Style="{ThemeResource BodyTextBlockStyle}" Foreground="Gray" />
            </StackPanel>
            
            <Button Grid.Column="1" Click="AddGame_Click" Style="{ThemeResource AccentButtonStyle}" VerticalAlignment="Center" Padding="16,8,16,8" CornerRadius="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE109;" FontSize="14" />
                    <TextBlock Text="Add Game" FontWeight="SemiBold" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Filter / Search bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,20" ColumnSpacing="12">
            <TextBox Grid.Column="0" x:Name="SearchBox" PlaceholderText="Search by title or tags..." TextChanged="SearchBox_TextChanged" Width="300" HorizontalAlignment="Left" />
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <TextBlock Text="Filter by Tag:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                <ComboBox x:Name="TagFilterCombo" SelectionChanged="TagFilterCombo_SelectionChanged" Width="150">
                    <ComboBoxItem Content="All Tags" IsSelected="True" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Game Library Grid -->
        <GridView Grid.Row="2"
                  x:Name="GamesGrid"
                  ItemsSource="{x:Bind FilteredGames}"
                  IsItemClickEnabled="True"
                  ItemClick="GamesGrid_ItemClick"
                  Padding="0,0,0,24"
                  SelectionMode="None">
            
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:Game">
                    <Grid Width="170" Margin="0,0,16,24" Background="#1D202B" CornerRadius="8" BorderThickness="1" BorderBrush="#2F3542"
                          AllowDrop="True" DragOver="Card_DragOver" Drop="Card_Drop" Tag="{x:Bind}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="240" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Cover image area with overlays -->
                        <Grid Grid.Row="0" CornerRadius="8,8,0,0" Background="#11141B">
                            <Image Source="{x:Bind CoverImageSource, Mode=OneWay}" Stretch="UniformToFill" Width="170" Height="240" />

                            <!-- Running overlay -->
                            <Grid Background="#CC111827" Visibility="{x:Bind RunningVisibility, Mode=OneWay}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                    <ProgressRing IsActive="True" Foreground="#2ECC71" Width="30" Height="30" />
                                    <TextBlock Text="RUNNING" FontWeight="Bold" Foreground="#2ECC71" FontSize="12" CharacterSpacing="100" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Info Area -->
                        <StackPanel Grid.Row="1" Padding="12" Spacing="6">
                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis" MaxLines="1" />
                            
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{x:Bind DisplayPlayTime, Mode=OneWay}" FontSize="12" Foreground="DarkGray" />
                                <FontIcon Grid.Column="1" Glyph="&#xE768;" FontSize="12" Foreground="LightGray" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Tags display -->
                            <ItemsControl ItemsSource="{x:Bind TagList, Mode=OneWay}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                    <DataTemplate>
                                        <Border Background="#373E4D" CornerRadius="4" Padding="6,2,6,2" Margin="0,0,4,4">
                                            <TextBlock Text="{Binding}" FontSize="10" Foreground="#E2E8F0" />
                                        </Border>
                                    </DataTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Right click Context Menu -->
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Launch Game" Click="LaunchGame_MenuClick" Icon="Play" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Edit Details" Click="EditGame_MenuClick" Icon="Edit" />
                                <MenuFlyoutItem Text="Change Cover Art" Click="ChangeCover_MenuClick" Icon="Pictures" />
                                <MenuFlyoutItem Text="Re-detect Executable" Click="ReDetectExe_MenuClick" Icon="Refresh" />
                                <MenuFlyoutItem Text="Repair Path" Click="RepairPath_MenuClick" Icon="Repair" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Remove Game" Click="RemoveGame_MenuClick" Icon="Delete" Foreground="Red" />
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
