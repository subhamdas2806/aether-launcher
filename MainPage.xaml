<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="GameShelf.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GameShelf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="24,12,24,24" RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4">
                <TextBlock Text="AETHER" FontSize="28" FontWeight="Bold" Foreground="#A29BFE" />
                <TextBlock Text="Launch and track playtime of standalone and custom builds" Style="{ThemeResource BodyTextBlockStyle}" Foreground="Gray" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Click="Settings_Click" Style="{ThemeResource DefaultButtonStyle}" Padding="16,8,16,8" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE713;" FontSize="14" />
                        <TextBlock Text="Settings" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Button Click="AddGame_Click" Style="{ThemeResource AccentButtonStyle}" Padding="16,8,16,8" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE109;" FontSize="14" />
                        <TextBlock Text="Add Game" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filter / Search bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,20" ColumnSpacing="12">
            <TextBox Grid.Column="0" x:Name="SearchBox" PlaceholderText="Search by title or tags..." TextChanged="SearchBox_TextChanged" Width="300" HorizontalAlignment="Left" />
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <TextBlock Text="Filter by Tag:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0"/>
                <ComboBox x:Name="TagFilterCombo" SelectionChanged="TagFilterCombo_SelectionChanged" Width="150">
                    <ComboBoxItem Content="All Tags" IsSelected="True" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Game Library Grid -->
        <GridView Grid.Row="2"
                  x:Name="GamesGrid"
                  ItemsSource="{x:Bind FilteredGames}"
                  IsItemClickEnabled="True"
                  ItemClick="GamesGrid_ItemClick"
                  Padding="0,0,0,24"
                  SelectionMode="None">
            
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:Game">
                    <Grid Width="180" Margin="0,0,16,24" 
                          PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited"
                          AllowDrop="True" DragOver="Card_DragOver" Drop="Card_Drop" Tag="{x:Bind}">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="CardScale" CenterX="90" CenterY="140" />
                                <TranslateTransform x:Name="CardTranslate" />
                            </TransformGroup>
                        </Grid.RenderTransform>
                        
                        <!-- Outer Clear Acrylic Case Border -->
                        <Border BorderThickness="3" Background="#1A1C23" CornerRadius="3" Padding="0" Margin="0">
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="CardBorderBrush" Color="#3BFFFFFF" />
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Left Hinge/Spine -->
                                    <ColumnDefinition Width="14" />
                                    <!-- Cover and Info Area -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Left Plastic Spine/Hinge -->
                                <Grid Grid.Column="0" Background="#121316">
                                    <Border Background="#090A0C" Margin="4,0,4,0" CornerRadius="1" />
                                    <Border BorderThickness="0,0,1,0" BorderBrush="#33FFFFFF" Opacity="0.3" />
                                    <Border BorderThickness="1,0,0,0" BorderBrush="#22FFFFFF" Opacity="0.2" />
                                </Grid>

                                <!-- Front Cover Insert & Info Inlay -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <!-- Top PC CD-ROM Banner -->
                                        <RowDefinition Height="18" />
                                        <!-- Cover Image -->
                                        <RowDefinition Height="200" />
                                        <!-- Info Tray Inlay -->
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 1. PC CD-ROM Banner -->
                                    <Grid Grid.Row="0" Background="White" Padding="4,0,4,0">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="PC CD-ROM" FontSize="9" FontWeight="Black" Foreground="Black" FontFamily="Impact, sans-serif" VerticalAlignment="Center" CharacterSpacing="50" />
                                            <FontIcon Grid.Column="1" Glyph="&#xE958;" FontSize="8" Foreground="Black" VerticalAlignment="Center" />
                                        </Grid>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="#CCCCCC" />
                                    </Grid>

                                    <!-- 2. Cover Art with Glossy Shine -->
                                    <Grid Grid.Row="1" Background="#0C0D11">
                                        <Image Source="{x:Bind CoverImageSource, Mode=OneWay}" Stretch="UniformToFill" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

                                        <!-- Running Overlay -->
                                        <Grid Background="#DD111827" Visibility="{x:Bind RunningVisibility, Mode=OneWay}">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                                <ProgressRing IsActive="True" Foreground="#2ECC71" Width="26" Height="26" />
                                                <TextBlock Text="RUNNING" FontWeight="Bold" Foreground="#2ECC71" FontSize="11" CharacterSpacing="100" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Glossy Plastic/Glass Reflection (Diagonal Sheen) -->
                                        <Grid IsHitTestVisible="False" Opacity="0.4">
                                            <Grid.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#00FFFFFF" Offset="0.0" />
                                                    <GradientStop x:Name="GlossStop1" Color="#00FFFFFF" Offset="0.0" />
                                                    <GradientStop x:Name="GlossStop2" Color="#4DFFFFFF" Offset="0.05" />
                                                    <GradientStop x:Name="GlossStop3" Color="#80FFFFFF" Offset="0.1" />
                                                    <GradientStop Color="#00FFFFFF" Offset="0.25" />
                                                    <GradientStop Color="#00FFFFFF" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Grid.Background>
                                        </Grid>
                                        
                                        <Border BorderThickness="1" BorderBrush="#22FFFFFF" Opacity="0.5" />
                                    </Grid>

                                    <!-- 3. Tray Inlay / Info Tray -->
                                    <StackPanel Grid.Row="2" Padding="10,8,10,8" Spacing="4" Background="#171A21">
                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="Bold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                        
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{x:Bind DisplayPlayTime, Mode=OneWay}" FontSize="11" Foreground="DarkGray" />
                                            <FontIcon Grid.Column="1" Glyph="&#xE768;" FontSize="11" Foreground="LightGray" VerticalAlignment="Center" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{x:Bind TagList, Mode=OneWay}" Margin="0,2,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#2B303C" CornerRadius="3" Padding="4,1,4,1" Margin="0,0,3,3">
                                                        <TextBlock Text="{Binding}" FontSize="9" Foreground="#CBD5E0" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Right click Context Menu -->
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Launch Game" Click="LaunchGame_MenuClick" Icon="Play" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Edit Details" Click="EditGame_MenuClick" Icon="Edit" />
                                <MenuFlyoutItem Text="Change Cover Art" Click="ChangeCover_MenuClick" Icon="Pictures" />
                                <MenuFlyoutItem Text="Re-detect Executable" Click="ReDetectExe_MenuClick" Icon="Refresh" />
                                <MenuFlyoutItem Text="Repair Path" Click="RepairPath_MenuClick" Icon="Repair" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Remove Game" Click="RemoveGame_MenuClick" Icon="Delete" Foreground="Red" />
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
